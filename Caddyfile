:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	root * /app/dist
	encode zstd gzip

	# Astro static routing:
	#   1) {path}            — exact file or directory (file_server then serves dir/index.html)
	#   2) {path}.html       — extensionless URLs like /comparativa-funcas → .html
	# No SPA fallback: real 404s reach handle_errors → 404.html
	try_files {path} {path}.html

	file_server

	handle_errors {
		@404 expression `{err.status_code} == 404`
		rewrite @404 /404.html
		file_server
	}
}
