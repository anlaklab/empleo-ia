---
import { SCORE_COLORS } from "@/lib/occupationData";

interface Props {
  score: number;
  size?: "sm" | "lg";
}

const { score, size = "sm" } = Astro.props;
const colorIndex = Math.round(Math.min(10, Math.max(0, score)));
const color = SCORE_COLORS[colorIndex];
const dim = size === "lg" ? 48 : 28;
const fontSize = size === "lg" ? 16 : 11;
---

<span
  style={`display:inline-flex;align-items:center;justify-content:center;width:${dim}px;height:${dim}px;border-radius:50%;background:${color};color:#fff;font-size:${fontSize}px;font-weight:700;font-family:'DM Sans',sans-serif;box-shadow:0 2px 8px ${color}66;flex-shrink:0;`}
>
  {score.toFixed(1)}
</span>
