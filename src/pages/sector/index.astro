---
import Base from "../../layouts/Base.astro";
import { SCORE_COLORS } from "@/lib/occupationData";
import { loadAllOccupations, getSectorStats, getAggregateStats } from "@/data/loadOccupations";

const { es } = loadAllOccupations();
const sectors = getSectorStats(es);
const stats = getAggregateStats(es);
const sorted = [...sectors].sort((a, b) => b.avgScore - a.avgScore);

const title = "Sectores del mercado laboral español — Vulnerabilidad a la IA";
const description = `Análisis de vulnerabilidad a la IA de los ${sectors.length} sectores económicos del mercado laboral español. ${stats.totalEmployment.toLocaleString("es-ES")} trabajadores en ${es.length} ocupaciones CNO-11.`;

const F = "'DM Sans', sans-serif";
const S = "'Cormorant Garamond', serif";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Sectores del mercado laboral español — Vulnerabilidad IA",
  "numberOfItems": sectors.length,
  "itemListElement": sorted.map((s, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://empleo-ai.anlakstudio.com/sector/${s.slug}`,
    "name": s.sector,
  })),
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div style={`background:#faf8f4;color:#1a1a1a;min-height:100vh;font-family:${F};`}>
    <div style="max-width:1200px;margin:0 auto;padding:28px 24px;">

      <!-- Breadcrumb -->
      <nav style="font-size:10px;text-transform:uppercase;letter-spacing:2.5px;color:#bbb;margin-bottom:6px;">
        <a href="/" style="color:#c8633a;text-decoration:none;">← Mapa interactivo</a>
      </nav>

      <!-- Header -->
      <h1 style={`font-size:clamp(26px,3.5vw,44px);font-family:${S};font-weight:600;margin:0 0 4px;line-height:1.08;color:#1a1a1a;`}>
        Sectores económicos
      </h1>
      <p style="font-size:14px;color:#888;line-height:1.55;margin:0 0 20px;">
        {sectors.length} sectores · {es.length} ocupaciones · {stats.totalEmployment.toLocaleString("es-ES")} trabajadores · Score medio IA: {stats.avgScore}/10
      </p>

      <!-- Stats ribbon -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px;">
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Total trabajadores</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>
            {(stats.totalEmployment / 1e6).toFixed(1)}M
          </div>
        </div>
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Exposición media</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>{stats.avgScore} / 10</div>
        </div>
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Alto riesgo (&gt;7)</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#c8633a;`}>
            {stats.highRiskCount} ocup.
          </div>
          <div style="font-size:11px;color:#999;margin-top:2px;">{stats.highRiskPct}% del empleo</div>
        </div>
      </div>

      <!-- Sector cards -->
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:12px;">
        {sorted.map((s) => {
          const colorIdx = Math.round(Math.min(10, Math.max(0, s.avgScore)));
          const color = SCORE_COLORS[colorIdx];
          const empLabel = s.employment >= 1e6 ? (s.employment / 1e6).toFixed(1) + "M" : s.employment >= 1e3 ? Math.round(s.employment / 1e3) + "K" : s.employment.toLocaleString("es-ES");
          return (
            <a href={`/sector/${s.slug}`} style="text-decoration:none;display:block;padding:20px;background:#f0ece4;border-radius:8px;border:1px solid #e0dcd4;transition:box-shadow 0.15s;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
                <h2 style={`font-size:18px;font-family:${S};font-weight:600;margin:0;color:#1a1a1a;line-height:1.2;`}>{s.sector}</h2>
                <div style={`width:36px;height:36px;border-radius:50%;background:${color};display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:700;flex-shrink:0;box-shadow:0 2px 8px ${color}44;`}>
                  {s.avgScore}
                </div>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;">
                <div>
                  <div style="font-size:9px;text-transform:uppercase;letter-spacing:0.8px;color:#aaa;">Ocupaciones</div>
                  <div style={`font-size:16px;font-weight:700;font-family:${S};color:#1a1a1a;`}>{s.count}</div>
                </div>
                <div>
                  <div style="font-size:9px;text-transform:uppercase;letter-spacing:0.8px;color:#aaa;">Empleo</div>
                  <div style={`font-size:16px;font-weight:700;font-family:${S};color:#1a1a1a;`}>{empLabel}</div>
                </div>
                <div>
                  <div style="font-size:9px;text-transform:uppercase;letter-spacing:0.8px;color:#aaa;">Salario medio</div>
                  <div style={`font-size:16px;font-weight:700;font-family:${S};color:#1a1a1a;`}>{s.avgSalary.toLocaleString("es-ES")} €</div>
                </div>
              </div>
              {s.highRiskCount > 0 && (
                <div style="font-size:10px;color:#c8633a;font-weight:600;">
                  {s.highRiskCount} ocupación{s.highRiskCount > 1 ? "es" : ""} con score &gt; 7/10
                </div>
              )}
            </a>
          );
        })}
      </div>

      <!-- Footer -->
      <div style="margin-top:24px;padding-top:16px;border-top:1px solid #e8e4dc;">
        <div style="font-size:10px;color:#bbb;line-height:1.65;">
          <strong style="color:#999;">Fuente:</strong> EPA Q4 2025, INE Census 2021, SEPE 2024 · Metodología v30 · CC BY 4.0 ·
          Autores: Álvaro de Nicolás, Miguel Sureda
        </div>
      </div>
    </div>
  </div>
</Base>
