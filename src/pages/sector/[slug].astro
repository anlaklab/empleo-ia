---
import Base from "../../layouts/Base.astro";
import ScoreBadgeStatic from "../../components/astro/ScoreBadgeStatic.astro";
import { loadAllOccupations, getSectorStats, sectorSlug, occupationSlug } from "@/data/loadOccupations";

export async function getStaticPaths() {
  const { es } = loadAllOccupations();
  const sectors = getSectorStats(es);
  return sectors.map((s) => ({
    params: { slug: s.slug },
    props: { sector: s },
  }));
}

const { sector } = Astro.props;

const title = `${sector.sector} — Vulnerabilidad a la IA por sector`;
const description = `Sector ${sector.sector}: ${sector.count} ocupaciones, ${sector.employment.toLocaleString("es-ES")} trabajadores, score medio de vulnerabilidad IA ${sector.avgScore}/10. ${sector.highRiskCount} ocupaciones de alto riesgo.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Ocupaciones del sector ${sector.sector} — Vulnerabilidad IA`,
  "numberOfItems": sector.count,
  "itemListElement": sector.occupations
    .sort((a, b) => b.vulnerabilidad_ia_score - a.vulnerabilidad_ia_score)
    .map((occ, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://empleo-ai.anlakstudio.com/ocupacion/${occupationSlug(occ)}`,
      "name": occ.nombre,
    })),
};

const sorted = [...sector.occupations].sort((a, b) => b.vulnerabilidad_ia_score - a.vulnerabilidad_ia_score);

const F = "'DM Sans', sans-serif";
const S = "'Cormorant Garamond', serif";
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <div style={`background:#faf8f4;color:#1a1a1a;min-height:100vh;font-family:${F};`}>
    <article style="max-width:1200px;margin:0 auto;padding:28px 24px;">

      <!-- Breadcrumb -->
      <nav style="font-size:10px;text-transform:uppercase;letter-spacing:2.5px;color:#bbb;margin-bottom:6px;">
        <a href="/" style="color:#c8633a;text-decoration:none;">Inicio</a>
        <span style="margin:0 4px;">›</span>
        <a href="/sector/" style="color:#c8633a;text-decoration:none;">Sectores</a>
        <span style="margin:0 4px;">›</span>
        <span>{sector.sector}</span>
      </nav>

      <!-- Header -->
      <h1 style={`font-size:clamp(26px,3.5vw,44px);font-family:${S};font-weight:600;margin:0 0 4px;line-height:1.08;color:#1a1a1a;`}>
        {sector.sector}
      </h1>
      <p style="font-size:14px;color:#888;line-height:1.55;margin:0 0 20px;">
        {sector.count} ocupaciones · {sector.employment.toLocaleString("es-ES")} trabajadores · Score medio IA: {sector.avgScore}/10
      </p>

      <!-- Stats ribbon -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;">
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Ocupaciones</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>{sector.count}</div>
        </div>
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Empleo total</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>
            {sector.employment >= 1e6 ? (sector.employment / 1e6).toFixed(1) + "M" : sector.employment.toLocaleString("es-ES")}
          </div>
          <div style="font-size:10px;color:#b08050;margin-top:2px;font-style:italic;">EPA Q4 2025</div>
        </div>
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Exposición media IA</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>{sector.avgScore} / 10</div>
          <div style="font-size:10px;color:#b08050;margin-top:2px;font-style:italic;">ponderado por empleo</div>
        </div>
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Salario medio</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>
            {sector.avgSalary.toLocaleString("es-ES")} €
          </div>
        </div>
        <div style="padding:12px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">Alto riesgo</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#c8633a;`}>
            {sector.highRiskCount}
          </div>
          <div style="font-size:11px;color:#999;margin-top:2px;">score &gt; 7/10</div>
        </div>
      </div>

      <!-- Employment disclaimer -->
      <div style="font-size:10px;color:#b08050;background:#fdf6ee;border:1px solid #f0dcc0;border-radius:5px;padding:8px 12px;margin-bottom:20px;line-height:1.5;">
        <strong>Nota:</strong> Las cifras de empleo son estimaciones basadas en EPA Q4 2025 y Censo 2021. Los scores son teóricos — no predicciones.
      </div>

      <!-- Occupations list -->
      <div style="display:flex;flex-direction:column;gap:2px;">
        <div style="display:grid;grid-template-columns:40px 1fr 110px 90px 90px 90px;gap:6px;padding:6px 10px;font-size:9px;text-transform:uppercase;letter-spacing:1px;color:#bbb;font-weight:600;border-bottom:1px solid #e8e4dc;">
          <div>Score</div>
          <div>Ocupación</div>
          <div>CNO</div>
          <div style="text-align:right;">Empleo</div>
          <div style="text-align:right;">Salario</div>
          <div style="text-align:right;">EU AI Act</div>
        </div>
        {sorted.map((occ, i) => (
          <a href={`/ocupacion/${occupationSlug(occ)}`} style={`display:grid;grid-template-columns:40px 1fr 110px 90px 90px 90px;gap:6px;padding:8px 10px;font-size:12px;background:${i % 2 === 0 ? "#f5f1eb" : "transparent"};border-radius:4px;text-decoration:none;color:#1a1a1a;align-items:center;`}>
            <div>
              <ScoreBadgeStatic score={occ.vulnerabilidad_ia_score} />
            </div>
            <div>
              <div style="font-weight:600;color:#1a1a1a;">{occ.nombre}</div>
            </div>
            <div style="font-size:10px;color:#bbb;">{occ.cno}</div>
            <div style="text-align:right;color:#555;font-variant-numeric:tabular-nums;">{occ.empleo.toLocaleString("es-ES")}</div>
            <div style="text-align:right;color:#555;font-variant-numeric:tabular-nums;">{occ.salario_medio_eur.toLocaleString("es-ES")} €</div>
            <div style="text-align:right;">
              <span style={`font-size:9px;padding:2px 7px;border-radius:8px;background:${occ.eu_ai_act.toLowerCase().includes("alto") || occ.eu_ai_act.toLowerCase().includes("high") ? "#c8633a15" : occ.eu_ai_act.toLowerCase().includes("limitado") || occ.eu_ai_act.toLowerCase().includes("limited") ? "#d4a85a15" : "#3a7d9e15"};color:${occ.eu_ai_act.toLowerCase().includes("alto") || occ.eu_ai_act.toLowerCase().includes("high") ? "#c8633a" : occ.eu_ai_act.toLowerCase().includes("limitado") || occ.eu_ai_act.toLowerCase().includes("limited") ? "#d4a85a" : "#3a7d9e"};font-weight:600;`}>
                {occ.eu_ai_act}
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Footer -->
      <div style="margin-top:24px;padding-top:16px;border-top:1px solid #e8e4dc;">
        <div style="font-size:10px;color:#bbb;line-height:1.65;">
          <strong style="color:#999;">Fuente:</strong> EPA Q4 2025, INE Census 2021, SEPE 2024 · Metodología v30 · CC BY 4.0 ·
          Autores: Álvaro de Nicolás, Miguel Sureda
        </div>
      </div>
    </article>
  </div>
</Base>
