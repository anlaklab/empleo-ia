---
import Base from "../layouts/Base.astro";
---

<Base title="Página no encontrada" description="La página que buscas no existe." noindex={true}>
  <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:'DM Sans',system-ui,sans-serif;background:#faf8f4;color:#1a1a1a;">
    <h1 style="font-size:48px;font-family:'Cormorant Garamond',serif;font-weight:600;margin:0 0 8px;">404</h1>
    <p style="font-size:14px;color:#888;margin:0 0 24px;">La página que buscas no existe.</p>
    <a href="/" style="padding:7px 14px;font-size:11px;font-weight:600;background:#1a1a1a;color:#faf8f4;border-radius:5px;text-decoration:none;letter-spacing:0.3px;">
      ← Volver al inicio
    </a>
  </div>
</Base>
