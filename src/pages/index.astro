---
import Base from "../layouts/Base.astro";
import DashboardIsland from "../components/react/DashboardIsland";
import OccupationTable from "../components/astro/OccupationTable.astro";
import SectorSummary from "../components/astro/SectorSummary.astro";
import { loadAllOccupations, getSectorStats, getAggregateStats, generateDatasetJsonLd, generateFaqJsonLd } from "../data/loadOccupations";

const { es, en } = loadAllOccupations();
const sectors = getSectorStats(es);
const stats = getAggregateStats(es);
const datasetJsonLd = generateDatasetJsonLd(es);
const faqJsonLd = generateFaqJsonLd(es);

const title = "Vulnerabilidad de Empleos a la IA en España";
const description = `Análisis interactivo de exposición a la IA de las ${es.length} ocupaciones del mercado laboral español · ${stats.totalEmployment.toLocaleString("es-ES")} trabajadores · EPA Q4 2025 · Metodología v30`;
---

<Base title={title} description={description} jsonLd={[datasetJsonLd, faqJsonLd]}>
  <!-- React Dashboard island — interactive, hydrated client-side -->
  <DashboardIsland client:load />

  <!-- Navigation to static pages -->
  <nav style="max-width:1200px;margin:0 auto;padding:16px 24px;font-family:'DM Sans',sans-serif;">
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;padding:14px 18px;background:#f0ece4;border-radius:8px;border:1px solid #e0dcd4;">
      <span style="font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:#999;font-weight:600;margin-right:4px;">Explorar datos</span>
      <a href="/sector/" style="display:inline-flex;align-items:center;gap:5px;padding:6px 14px;font-size:11px;font-weight:600;background:#1a1a1a;color:#faf8f4;border-radius:5px;text-decoration:none;letter-spacing:0.3px;">
        📊 Ver los {sectors.length} sectores
      </a>
      <a href="#seo-occupation-table" style="display:inline-flex;align-items:center;gap:5px;padding:6px 14px;font-size:11px;font-weight:600;background:transparent;color:#666;border:1px solid #d8d4cc;border-radius:5px;text-decoration:none;letter-spacing:0.3px;">
        📋 Tabla de {es.length} ocupaciones
      </a>
      <a href="/llms.txt" style="display:inline-flex;align-items:center;gap:5px;padding:6px 14px;font-size:11px;font-weight:600;background:transparent;color:#666;border:1px solid #d8d4cc;border-radius:5px;text-decoration:none;letter-spacing:0.3px;">
        🤖 llms.txt
      </a>
    </div>
  </nav>

  <!-- Static SEO content — zero JS, visible to all crawlers and LLMs -->
  <SectorSummary sectors={sectors} />
  <OccupationTable occupations={es} enOccupations={en} />
</Base>
